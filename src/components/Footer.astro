---
import { SOCIAL_LINKS, NAV_LINKS, SITE, ICON_MAP } from '@/consts'
import Link from '@/components/Link.astro'
import { Icon } from 'astro-icon/components'
import type { SocialLink } from '@/types'
---

<footer class="border-t border-border/40">
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <nav class="flex items-center gap-4 text-sm text-muted-foreground">
        {NAV_LINKS.map((item) => (
          <Link href={item.href} class="hover:text-foreground transition-colors capitalize">
            {item.label}
          </Link>
        ))}
      </nav>

      <div class="flex items-center gap-3">
        {SOCIAL_LINKS.map(({ href, label }: SocialLink) => (
          <Link
            href={href}
            aria-label={label}
            title={label}
            class="text-muted-foreground/60 hover:text-foreground transition-colors"
            external
          >
            <Icon
              name={ICON_MAP[label as keyof typeof ICON_MAP] || 'lucide:message-circle-question'}
              class="size-4"
            />
          </Link>
        ))}
      </div>
    </div>

    <p class="text-xs text-muted-foreground/50 text-center mt-6">
      &copy; {new Date().getFullYear()} {SITE.title}
    </p>
  </div>
</footer>
