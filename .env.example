# Analytics (Optional)
# Google Analytics - Get your tracking ID from https://analytics.google.com/
PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Umami Analytics - Get your website ID from your Umami instance
PUBLIC_UMAMI_WEBSITE_ID=your-umami-website-id

# Disqus Comments (Optional)
# Get your shortname from https://disqus.com/admin/settings/general/
PUBLIC_DISQUS_SHORTNAME=your-shortname
